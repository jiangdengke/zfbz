# =========================
# HaoWallpaper 每日爬取配置
# 文件名：.env
# 启动：python3 scripts/haowallpaper_daily_daemon.py --run-now --run-at 03:30
# =========================

# ------------------------------------------------------------
# 1) 代理来源，二选一。
# 配置 RELAY_BASE 时优先使用 relay；否则使用 DM_PROXY_API。
# ------------------------------------------------------------

# 自建 URL 转发/relay 代理池
RELAY_BASE='https://你的relay域名/你的用户/你的池子'

# 大漠批量代理 API；不用大漠就注释掉
# DM_PROXY_API='http://need1.dmdaili.com:7771/dmgetip.asp?apikey=你的apikey&pwd=你的pwd&getnum=10000&httptype=1&geshi=2&fenge=1&fengefu=&operate=all'

# ------------------------------------------------------------
# 2) Python 调度器参数
# ------------------------------------------------------------

# 每天几点自动跑
HAOWALLPAPER_RUN_AT=03:30

# 每个任务如果脚本异常退出，整任务额外重试几次；0=不重试
RUN_RETRIES=1

# ------------------------------------------------------------
# 3) 下载通用参数
# ------------------------------------------------------------

# original=原图，preview=预览图，thumb=缩略图
QUALITY=original

# 每页拉多少条，网站常用 12
ROWS=12

# 每次最多扫描多少页；实际会按网站总页数自动停止
PAGES=10000

# 并发数；服务器稳定建议 20~50，代理强可以 100
CONCURRENCY=50

# 每张任务之间延迟毫秒；0=不延迟
DELAY=0

# 默认每日新增下载上限；每个任务也可以单独覆盖
DAILY_LIMIT=300

# 列表接口失败重试次数
LIST_RETRIES=10

# 每张图最多尝试多少个代理/relay 签名请求
PROXY_RETRIES=5000

# 单次代理/relay 请求超时秒数
PROXY_TIMEOUT=8

# 默认排序；3 是脚本默认推荐排序。也可在每个任务里单独覆盖。
SORT=3

# 默认搜索词；空=不搜索。也可在每个任务里单独覆盖。
SEARCH=

# ------------------------------------------------------------
# 4) 跑什么图：任务列表
# ------------------------------------------------------------
# 每行格式：
#   名称|wp-type|kind|输出目录|进度文件|本任务每日新增上限|排序|搜索词
#
# wp-type：
#   1     = 电脑静态图
#   2     = 手机静态图
#   3,4   = 电脑动态壁纸
#   5,6   = 手机动态壁纸
#
# kind：
#   image = 只跑图片
#   video = 只跑动态/视频
#   all   = 图片和视频都跑
#
# 搜索词示例：风景、二次元、美女、动漫、城市、游戏、汽车、猫、4K
# 不想搜索就留空。
# ------------------------------------------------------------

WALLPAPER_JOBS='pc-image|1|image|downloads/haowallpaper-pc-image|state/haowallpaper-pc-image.json|300|3|
mobile-image|2|image|downloads/haowallpaper-mobile-image|state/haowallpaper-mobile-image.json|300|3|
pc-video|3,4|video|downloads/haowallpaper-pc-video|state/haowallpaper-pc-video.json|50|3|
mobile-video|5,6|video|downloads/haowallpaper-mobile-video|state/haowallpaper-mobile-video.json|50|3|'

# ------------------------------------------------------------
# 5) 可选：上传/搬运到 Google Drive
# ------------------------------------------------------------
# 需要服务器先安装并配置 rclone remote，例如 remote 名叫 gdrive:
#
# RCLONE_ENABLE=1 开启上传。
# RCLONE_MODE:
#   move = 上传后删除服务器本地图片，省服务器硬盘，推荐长期跑。
#   copy = 上传后本地也保留。
#   sync = 镜像同步，慎用，会让网盘目标和本地目录保持一致。
#
# 注意：如果使用 move，不要删除 state/ 目录；state 会记录进度，避免重复跑。
# ------------------------------------------------------------

RCLONE_ENABLE=0
RCLONE_REMOTE='gdrive:'
RCLONE_BASE_DIR='haowallpaper'
RCLONE_MODE=move
RCLONE_TRANSFERS=8
RCLONE_CHECKERS=16
# 不限速就注释掉；限速示例：RCLONE_BWLIMIT=20M
# RCLONE_BWLIMIT=20M
RCLONE_FAIL_FATAL=0

# ------------------------------------------------------------
# 6) 例子：只跑特定题材时，可以把上面的 WALLPAPER_JOBS 改成这样
# ------------------------------------------------------------
# WALLPAPER_JOBS='pc-scenery|1|image|downloads/pc-scenery|state/pc-scenery.json|200|3|风景
# pc-anime|1|image|downloads/pc-anime|state/pc-anime.json|200|3|二次元
# mobile-anime|2|image|downloads/mobile-anime|state/mobile-anime.json|200|3|动漫'
