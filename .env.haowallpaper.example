# 复制成 .env.haowallpaper，然后二选一配置代理来源

# 方式1：大漠批量代理 API
DM_PROXY_API='http://need1.dmdaili.com:7771/dmgetip.asp?apikey=你的apikey&pwd=你的pwd&getnum=10000&httptype=1&geshi=2&fenge=1&fengefu=&operate=all'

# 方式2：自建 URL 转发/relay 代理；如果配置了 RELAY_BASE，会优先使用它
# RELAY_BASE='https://你的relay域名/你的用户/你的池子'

# 通用参数
QUALITY=original
ROWS=12
PAGES=10000
CONCURRENCY=50
PROXY_TIMEOUT=8
PROXY_RETRIES=5000
DELAY=0

# 默认每日上限；每个任务也可以在 WALLPAPER_JOBS 里单独配置
DAILY_LIMIT=300

# 多任务列表，每行格式：名称|wp-type|kind|输出目录|进度文件|本任务每日新增上限
# wp-type: 1=电脑静图, 2=手机静图, 3/4=电脑动态, 5/6=手机动态
# kind: image / video / all
WALLPAPER_JOBS='pc-image|1|image|downloads/haowallpaper-pc-image|state/haowallpaper-pc-image.json|300
mobile-image|2|image|downloads/haowallpaper-mobile-image|state/haowallpaper-mobile-image.json|300
pc-video|3,4|video|downloads/haowallpaper-pc-video|state/haowallpaper-pc-video.json|50
mobile-video|5,6|video|downloads/haowallpaper-mobile-video|state/haowallpaper-mobile-video.json|50'
